# =============================================
# CloneAI Backend — Environment Variables
# Copy this file to .env and fill in values
# =============================================

# Required: Your Anthropic API key
# Get it at https://console.anthropic.com/
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: MongoDB connection string
# Leave blank to use in-memory store (data resets on restart)
# Format: mongodb+srv://user:password@cluster.mongodb.net/cloneai
MONGODB_URI=

# Server port (default: 3001)
PORT=3001

# Frontend URL for CORS (your Vercel URL in production)
FRONTEND_URL=http://localhost:5173
